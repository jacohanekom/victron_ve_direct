#!/usr/bin/make -f
%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release

override_dh_auto_install:
	dh_auto_install
	install -D -m 0644 config.ini \
		debian/victron-ve-direct/etc/victron-ve-direct/config.ini
	install -D -m 0644 debian/50-victron-ve-direct.rules \
		debian/victron-ve-direct/usr/lib/udev/rules.d/50-victron-ve-direct.rules

override_dh_installsystemd:
	dh_installsystemd --no-restart-on-upgrade --no-stop-on-upgrade
