#!/bin/sh
set -e
case "$1" in
    remove|purge)
        if systemctl is-active --quiet victron-ve-direct.service 2>/dev/null; then
            systemctl stop victron-ve-direct.service || true
        fi
        if systemctl is-enabled --quiet victron-ve-direct.service 2>/dev/null; then
            systemctl disable victron-ve-direct.service || true
        fi
        ;;
esac
#DEBHELPER#
exit 0
